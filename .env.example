# =====================================================================
# Firebase — CLIENT (published to the browser via NEXT_PUBLIC_* prefix)
# =====================================================================
# Get these from: Firebase Console → Project settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =====================================================================
# Firebase — ADMIN (server only — NEVER prefix with NEXT_PUBLIC_)
# =====================================================================
# From Firebase Console → Project settings → Service accounts → generate key.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# =====================================================================
# Google Gemini (server only)
# =====================================================================
# From https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =====================================================================
# App behavior
# =====================================================================
# Per-user daily limit on AI generations (full + section count together).
AI_DAILY_USER_CAP=10
